# TriniBuild Environment Variables

# =====================================================
# Supabase Configuration
# =====================================================
VITE_SUPABASE_URL=https://cdprbbyptjdntcrhmwxf.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_URL=https://cdprbbyptjdntcrhmwxf.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =====================================================
# Payment Methods (Trinidad & Tobago)
# =====================================================

# PayPal (Available Now)
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret

# WiPay (Coming Soon - Trinidad & Tobago)
# VITE_WIPAY_MERCHANT_ID=your_wipay_merchant_id
# WIPAY_API_KEY=your_wipay_api_key

# Trinidad Bank Transfer (Coming Soon)
# VITE_TTBANK_ACCOUNT=your_business_account_number
# VITE_TTBANK_NAME=your_bank_name

# =====================================================
# Google Maps (For Ride Tracking)
# =====================================================
VITE_GOOGLE_MAPS_BROWSER_KEY=your_domain_restricted_google_maps_browser_key

# =====================================================
# Monitoring & Analytics
# =====================================================

# Sentry Error Monitoring
VITE_SENTRY_DSN=your_sentry_dsn

# Google Analytics
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# =====================================================
# App Configuration
# =====================================================
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production
VITE_APP_NAME=TriniBuild

# =====================================================
# AI & Content Generation
# =====================================================

# Server-side AI gateway. Use an OpenAI-compatible local model server for Qwen.
# Ollama example: LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# vLLM example:   LOCAL_LLM_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_API_KEY=not-needed
LOCAL_LLM_MODEL=qwen3:8b

# Optional server-side fallback. Do not expose this as VITE_*.
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# =====================================================
# Email & SMS (Optional)
# =====================================================

# SendGrid for emails
SENDGRID_API_KEY=your_sendgrid_key

# Listmonk (Email Marketing - Self-hosted)
LISTMONK_API_KEY=your_listmonk_api_key
VITE_LISTMONK_URL=https://listmonk.yourdomain.com

# Twilio for SMS
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1868XXXXXXX

# =====================================================
# Social Media (Optional)
# =====================================================
VITE_FACEBOOK_APP_ID=your_facebook_app_id
INSTAGRAM_TOKEN=your_instagram_token

# =====================================================
# Notes
# =====================================================
# - Never commit this file to Git (.env is in .gitignore)
# - Use .env.local for local development
# - Use environment variables in hosting platform for production
# - PayPal and COD are available now
# - WiPay and Trinidad Bank Transfer coming soon
