// TriniBuild Prisma Schema
// SQLite-compatible (no arrays, JSON, or enums)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  phone             String?   @unique
  firstName         String
  lastName          String
  password          String
  role              String    @default("customer") // "seller" or "customer"

  // Verification
  phoneVerified     DateTime?
  emailVerified     DateTime?

  // Status
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  vendors           Vendor[]
  orders            Order[]
  cart              Cart?
  payments          Payment[]
  notifications     Notification[]
  notificationEmails NotificationEmail[]
  refunds           Refund[]
}

// ============================================
// SELLER / STORE
// ============================================

model Vendor {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Store Info
  storeName         String
  storeUrl          String    @unique
  storeDescription  String?
  logo              String?   // URL to logo image
  bannerColor       String    @default("#000000") // hex color
  theme             String    @default("minimal") // template name

  // Contact
  phone             String?
  email             String?
  address           String?
  city              String?
  country           String?

  // Status
  isPublished       Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  products          Product[]
  orders            Order[]
}

// ============================================
// PRODUCTS
// ============================================

model Product {
  id                String    @id @default(cuid())
  vendorId          String
  vendor            Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  // Product Info
  name              String
  title             String?   // alternate name field
  description       String?
  brand             String?
  price             Float
  discount          Float     @default(0) // discount percentage
  rating            Float     @default(0) // average rating
  views             Int       @default(0) // view count
  category          String    @default("general")

  // Media
  imageUrl          String?   // single main image URL

  // Features
  tags              String?   // comma-separated tags
  isFeatured        Boolean   @default(false)
  isFlashSale       Boolean   @default(false)
  flashSaleEndDate  DateTime? // when flash sale ends
  reviews           Int       @default(0) // number of reviews

  // Inventory
  stock             Int       @default(0)
  sku               String?

  // Status
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  cartItems         CartItem[]
  orderItems        OrderItem[]
}

// ============================================
// SHOPPING CART
// ============================================

model Cart {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  items             CartItem[]
}

model CartItem {
  id                String    @id @default(cuid())
  cartId            String
  cart              Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity          Int       @default(1)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([cartId, productId])
}

// ============================================
// ORDERS & ORDER ITEMS
// ============================================

model Order {
  id                String    @id @default(cuid())
  orderNumber       String    @unique // human-readable order ID

  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  vendorId          String
  vendor            Vendor    @relation(fields: [vendorId], references: [id])

  // Customer Details
  customerName      String
  customerEmail     String
  customerPhone     String?

  // Shipping Address
  shippingAddress   String
  shippingCity      String
  shippingCountry   String?
  shippingZip       String?

  // Order Info
  totalAmount       Float
  status            String    @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  paymentStatus     String    @default("PENDING") // PENDING, COMPLETED, FAILED
  paymentMethod     String    @default("COD") // COD, etc.
  notes             String?
  cancelReason      String?   // reason for cancellation if cancelled
  canceledAt        DateTime? // when order was canceled

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  items             OrderItem[]
  payment           Payment?
}

model OrderItem {
  id                String    @id @default(cuid())
  orderId           String
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId         String
  product           Product   @relation(fields: [productId], references: [id])

  vendorId          String    // denormalize for quick access
  quantity          Int
  price             Float
  priceAtPurchase   Float
  subtotal          Float     @default(0) // quantity * price
  status            String    @default("pending") // order item status

  createdAt         DateTime  @default(now())
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id                String    @id @default(cuid())
  orderId           String    @unique
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  userId            String
  user              User      @relation(fields: [userId], references: [id])

  // Payment Info
  amount            Float
  currency          String    @default("USD") // currency code
  method            String    @default("COD") // COD, CARD, TRANSFER, etc.
  status            String    @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED

  // External References
  transactionId     String?   // external payment reference
  paymentIntentId   String?   // stripe or other provider ID
  paymentId         String?   // alternate payment ID reference
  failureMessage    String?   // error message if failed

  // COD-specific
  deliveredOn       DateTime?
  paidOn            DateTime?

  // Metadata
  notes             String?

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              String    // order_update, payment, etc.
  title             String
  message           String
  read              Boolean   @default(false)
  readAt            DateTime?
  relatedOrderId    String?   // link to related order if applicable

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model NotificationEmail {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  email             String
  subject           String
  body              String
  sent              Boolean   @default(false)
  sentAt            DateTime?

  createdAt         DateTime  @default(now())
}

// ============================================
// REFUNDS
// ============================================

model Refund {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId           String
  paymentId         String?   // link to payment being refunded
  amount            Float
  reason            String
  status            String    @default("pending") // pending, approved, rejected, completed
  notes             String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ============================================
// PROFESSIONAL SERVICES
// ============================================

model TriniWorksProfessional {
  id                String    @id @default(cuid())
  userId            String    @unique

  title             String    // job title
  category          String    // service category
  description       String?
  hourlyRate        Float?
  bio               String?
  profileImage      String?

  isVerified        Boolean   @default(false)
  rating            Float     @default(0)
  reviews           Int       @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
