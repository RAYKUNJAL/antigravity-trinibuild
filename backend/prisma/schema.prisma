// TriniBuild Prisma Schema - Minimal Version for Phase 1 & 2
// SQLite-compatible (no arrays, JSON, or enums)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  phone             String?   @unique
  firstName         String
  lastName          String
  password          String
  role              String    @default("customer") // "seller" or "customer"

  // Verification
  phoneVerified     DateTime?

  // Status
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  vendors           Vendor[]
  orders            Order[]
  cart              Cart?
  payments          Payment[]
}

// ============================================
// SELLER / STORE
// ============================================

model Vendor {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Store Info
  storeName         String
  storeUrl          String    @unique
  storeDescription  String?
  logo              String?   // URL to logo image
  bannerColor       String    @default("#000000") // hex color
  theme             String    @default("minimal") // template name

  // Contact
  phone             String?
  email             String?
  address           String?
  city              String?
  country           String?

  // Status
  isPublished       Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  products          Product[]
  orders            Order[]
}

// ============================================
// PRODUCTS
// ============================================

model Product {
  id                String    @id @default(cuid())
  vendorId          String
  vendor            Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  // Product Info
  name              String
  description       String?
  price             Float
  category          String    @default("general")

  // Media
  imageUrl          String?   // single main image URL

  // Inventory
  stock             Int       @default(0)
  sku               String?

  // Status
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  cartItems         CartItem[]
  orderItems        OrderItem[]
}

// ============================================
// SHOPPING CART
// ============================================

model Cart {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  items             CartItem[]
}

model CartItem {
  id                String    @id @default(cuid())
  cartId            String
  cart              Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity          Int       @default(1)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ============================================
// ORDERS & ORDER ITEMS
// ============================================

model Order {
  id                String    @id @default(cuid())
  orderNumber       String    @unique // human-readable order ID

  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  vendorId          String
  vendor            Vendor    @relation(fields: [vendorId], references: [id])

  // Customer Details
  customerName      String
  customerEmail     String
  customerPhone     String?

  // Shipping Address
  shippingAddress   String
  shippingCity      String
  shippingCountry   String?
  shippingZip       String?

  // Order Info
  totalAmount       Float
  status            String    @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  paymentStatus     String    @default("PENDING") // PENDING, COMPLETED, FAILED
  paymentMethod     String    @default("COD") // COD, etc.
  notes             String?

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  items             OrderItem[]
  payment           Payment?
}

model OrderItem {
  id                String    @id @default(cuid())
  orderId           String
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId         String
  product           Product   @relation(fields: [productId], references: [id])

  quantity          Int
  priceAtPurchase   Float

  createdAt         DateTime  @default(now())
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id                String    @id @default(cuid())
  orderId           String    @unique
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  userId            String
  user              User      @relation(fields: [userId], references: [id])

  // Payment Info
  amount            Float
  method            String    @default("COD") // COD, CARD, TRANSFER, etc.
  status            String    @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED

  // COD-specific
  deliveredOn       DateTime?
  paidOn            DateTime?

  // Metadata
  notes             String?

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
